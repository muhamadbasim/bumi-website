<div class="brand-loader" data-brand-loader aria-hidden="true">
  <img src="/brand/bumi-logo-app-dark.svg" alt="" width="64" height="64" />
</div>
<noscript><style>.brand-loader { display:none !important; }</style></noscript>

<script is:inline>
  const loader = document.querySelector('[data-brand-loader]')
  const removeLoader = () => loader?.remove()
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches

  if (reducedMotion || document.readyState === 'complete') removeLoader()
  else window.addEventListener('load', removeLoader, { once: true })

  window.setTimeout(removeLoader, 1200)
</script>
